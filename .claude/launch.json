{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "python",
      "runtimeArgs": [
        "-m", "uvicorn", "app.main:app",
        "--app-dir", "regis/backend",
        "--host", "127.0.0.1", "--port", "8000"
      ],
      "port": 8000
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "regis/frontend", "run", "dev"],
      "port": 3000
    }
  ]
}
