# Regis backend — copy to .env for local dev. All keys are REGIS_-prefixed.

REGIS_ENV=dev

# Postgres (use the docker-compose service in dev). SQLite is tests-only.
REGIS_DATABASE_URL=postgresql+psycopg://regis:regis@localhost:5432/regis
REGIS_REDIS_URL=redis://localhost:6379/0

# AWS / storage — ap-south-1 (data residency, non-negotiable for NBFC trust)
REGIS_AWS_REGION=ap-south-1
REGIS_S3_BUCKET=regis-evidence-dev

# AI (Claude Sonnet for all V1 AI). Leave unset to run deterministic-only offline.
REGIS_ANTHROPIC_API_KEY=
REGIS_ANTHROPIC_MODEL=claude-sonnet-4-6
REGIS_QDRANT_URL=http://localhost:6333

# Auth
REGIS_JWT_SECRET=dev-only-change-me
REGIS_ACCESS_TOKEN_TTL_MINUTES=720

# Field-level encryption for PAN/CIN/TAN (Fernet key). REQUIRED in prod.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
REGIS_FIELD_KEY=

# Platform content team: comma-separated emails allowed to publish legal updates
# (the feed is global across all tenants). Empty = API publishing disabled.
REGIS_CONTENT_ADMIN_EMAILS=
